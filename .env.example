# PostgreSQL
POSTGRES_USER=erddbml_user
POSTGRES_PASSWORD=postgres_dev
POSTGRES_DB=erddbml_dev
# Host port to publish postgres on (container port is always 5432). Override if 5432
# is already taken on your host; inter-container access always uses "postgres:5432".
POSTGRES_HOST_PORT=5432

# Backend (async SQLAlchemy requires the postgresql+asyncpg:// scheme;
# host "postgres" is the compose service name resolved via the shared network)
DATABASE_URL=postgresql+asyncpg://erddbml_user:postgres_dev@postgres:5432/erddbml_dev
CORS_ORIGINS=http://localhost:5173
ENVIRONMENT=development
DEBUG=true

# Authentication (fastapi-users JWT + httpOnly cookie).
# SECRET_KEY signs JWTs — generate a strong value for production (e.g. `openssl rand -hex 32`).
SECRET_KEY=change-me-dev-only-not-for-production
JWT_LIFETIME_SECONDS=3600
# COOKIE_SECURE=true in production (https only); false for local http dev.
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# Frontend (browser client). "/api" routes through the Vite dev-proxy to the backend.
VITE_API_URL=/api
# Frontend (in-container Vite dev server). Target the backend via compose DNS so the
# Vite proxy forwards "/api" to the backend service ("localhost" would mean the frontend container).
VITE_PROXY_TARGET=http://backend:8000
